# ── Required ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AGENT_API_KEY=replace-with-a-long-random-secret

# ── Optional ────────────────────────────────────────────────────────────────────
AGENT_PORT=5001

# Default OU for new users (leave blank to use the domain default Users container)
# AD_USERS_OU=OU=Staff,OU=Users,DC=contoso,DC=com

# Trigger an Azure AD Connect delta sync after each user is created (best-effort).
# Requires the ADSync module on this machine, OR set ADSYNC_SERVER to the AAD
# Connect server (reached via WinRM). Set to false to disable.
ADSYNC_ENABLED=true
# ADSYNC_SERVER=aadconnect01.contoso.com
